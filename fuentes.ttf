import gifos
from datetime import datetime

# Configuración de la ruta de la fuente
FONT_FILE = "./fonts/font.ttf" 

def main():
    # 1. Crear la terminal (Ancho: 700, Alto: 400)
    # El tamaño de fuente 15 es el estándar ideal para lectura
    t = gifos.Terminal(700, 400, 20, 20, FONT_FILE, 15)
    t.set_fps(15)
    
    # 2. El Prompt (Apariencia: gael@github:~$)
    # \x1b[1;32m = Verde | \x1b[1;34m = Azul | \x1b[0m = Reset
    t.set_prompt("\x1b[1;32mgael\x1b[0m@\x1b[1;34mgithub\x1b[0m:~\x1b[1;33m$\x1b[0m ")
    t.gen_prompt(1)
    
    # 3. Primera acción: Escribir el mensaje inicial
    t.gen_typing_text("gael comenzo...", 1, contin=True)
    t.clone_frame(10)
    
    # 4. Segunda acción: Simular ejecución de código
    t.gen_prompt(3)
    t.gen_typing_text("python3 github_bot.py --action=write", 3, contin=True)
    t.clone_frame(5)
    
    # 5. Tercera acción: Animación de progreso circular y barra
    t.gen_text("Optimizando archivos del repositorio...", 5)
    
    # Caracteres para el círculo animado (spinner)
    spinner = ['-', '\\', '|', '/']
    pasos = 20 # Cuántos pasos tendrá la barra
    
    for i in range(pasos + 1):
        porcentaje = (i * 100) // pasos
        # Barra de progreso visual
        lleno = i // 2
        barra_visual = "█" * lleno + "░" * (10 - lleno)
        
        # Seleccionar el ícono del círculo
        icono = spinner[i % 4]
        
        # Dibujar la línea de progreso en la fila 7
        t.delete_row(7)
        # \x1b[36m es color Cian para que resalte
        t.gen_text(f"\x1b[36m{icono}\x1b[0m Escribiendo: [{barra_visual}] {porcentaje}%", 7)
        t.clone_frame(2)

    # 6. Cuarta acción: Mensaje de éxito final
    t.gen_text("\x1b[1;32m[SUCCESS]\x1b[0m Gael ha completado la tarea.", 9)
    t.gen_prompt(11)
    
    # 7. Pausa de cierre (para que el GIF no reinicie instantáneamente)
    t.clone_frame(50) 
    
    # 8. Generar el archivo GIF
    t.gen_gif()

if __name__ == "__main__":
    main()
