import os
import requests

def descargar_fuente():
    # Crear carpeta fonts si no existe
    if not os.path.exists('fonts'):
        os.makedirs('fonts')
        print("Carpeta /fonts creada.")

    # URL de una fuente estándar y limpia (JetBrains Mono)
    url = "https://github.com/JetBrains/JetBrainsMono/raw/master/fonts/ttf/JetBrainsMono-Regular.ttf"
    
    print("Descargando fuente estándar...")
    response = requests.get(url)
    
    if response.status_code == 200:
        with open("fonts/font.ttf", "wb") as f:
            f.write(response.content)
        print("¡Éxito! Fuente guardada en fonts/font.ttf")
    else:
        print("Error al descargar la fuente.")

if __name__ == "__main__":
    descargar_fuente()
